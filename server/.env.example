# ── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net/
DB_NAME=E-commers

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRETKEY=your_cryptr_secret_key
JWT_SECRET=your_jwt_secret

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_API_KEY=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Nodemailer (Gmail) ────────────────────────────────────────────────────────
# Use a Gmail App Password — NOT your regular Gmail password.
# Enable 2FA then generate one at: https://myaccount.google.com/apppasswords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
